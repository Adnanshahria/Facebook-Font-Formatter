rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: visitors
    // Document ID: {visitorId}
    // Fields:
    //   - id: string (required)
    //   - visitedAt: timestamp (required)
    //
    // Collection: user_contents
    // Document ID: {contentId}
    // Fields:
    //   - email: string (required)
    //   - originalText: string (required)
    //   - formattedText: string (required)
    //   - serialNumber: number (required)
    //   - createdAt: timestamp (required)
    // ===============================================================

    function hasRequiredVisitorFields() {
      return request.resource.data.keys().hasAll(['id', 'visitedAt']);
    }

    function hasRequiredContentFields() {
      return request.resource.data.keys().hasAll(['email', 'originalText', 'formattedText', 'serialNumber', 'createdAt']);
    }

    match /visitors/{visitorId} {
      // Allow anyone to register as a visitor
      allow create, update: if hasRequiredVisitorFields();
      // Allow read for admin panel (Prototype: open read, requires hardening for production)
      allow read: if true; 
    }

    match /user_contents/{contentId} {
      // Allow anyone to save content
      allow create: if hasRequiredContentFields();
      // Allow read for admin panel (Prototype: open read, requires hardening for production)
      allow read: if true;
    }
  }
}
